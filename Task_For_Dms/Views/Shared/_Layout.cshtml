<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Task_For_Dms</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <header class="bg-white shadow-sm">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <a class="text-xl font-bold text-blue-600 hover:text-blue-800 transition"
               asp-area="" asp-controller="Home" asp-action="Index">
                Task_For_Dms
            </a>
            <nav class="flex space-x-6">
                <a class="text-gray-700 hover:text-blue-600 font-medium transition"
                   asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="text-gray-700 hover:text-blue-600 font-medium transition"
                   asp-area="" asp-controller="Device" asp-action="Index">Devices</a>
                <a class="text-gray-700 hover:text-blue-600 font-medium transition"
                   asp-area="" asp-controller="Device" asp-action="PropertyItems">Property Items</a>
            </nav>
        </div>
    </header>
    <main class="container mx-auto px-4 py-6 flex-grow">
        @RenderBody()
    </main>
    <footer class="bg-white border-t mt-auto">
        <div class="container mx-auto px-4 py-4 text-center text-gray-600 text-sm">
            &copy; 2025 - Task_For_Dms -
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>